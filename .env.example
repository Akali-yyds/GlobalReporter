# GlobalReporter Environment Configuration

# Project
PROJECT_NAME=ainewser

# PostgreSQL
POSTGRES_USER=ainewser
POSTGRES_PASSWORD=ainewser_secure_pass_2024
POSTGRES_DB=ainewser
POSTGRES_PORT=5432

# API Service
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Web App
WEB_PORT=3000

# Database URL (used by API and Crawler)
DATABASE_URL=postgresql://ainewser:ainewser_secure_pass_2024@localhost:5432/ainewser

# Base URL of the FastAPI process — Scrapy POSTs crawled items to /api/news/ingest
API_BASE_URL=http://127.0.0.1:8000

# API: background crawler (runs `scrapy crawl` in ../crawler-service)
CRAWLER_ENABLED=true
CRAWLER_INTERVAL_SECONDS=300
CRAWLER_SPIDER=sina
# Optional: Python that has Scrapy if not installed in API venv (Windows example):
# CRAWLER_PYTHON=D:\\MYCODE\\MYPROJECT\\GlobalReporter\\crawler-service\\.venv\\Scripts\\python.exe

# Web dev: proxy /api to your API port (8000, 8123, etc.)
VITE_API_PROXY_TARGET=http://localhost:8000
