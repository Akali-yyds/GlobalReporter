# GlobalReporter Environment Configuration

# Project
PROJECT_NAME=ainewser

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123321
POSTGRES_DB=ainewser
POSTGRES_PORT=5432

# API Service
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CRAWLER_INTERVAL_SECONDS=3600

# Web App
WEB_PORT=3000

# Database URL (used by API and Crawler)
DATABASE_URL=postgresql://postgres:123321@localhost:5432/ainewser?client_encoding=UTF8
